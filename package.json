{
  "name": "kira-sekira",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "postinstall": "npm run generate:types -w studio",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "types": "npm run generate:types -w studio",
    "start:all": "concurrently \"npm run start -w main\" \"npm run start -w models\" \"npm run dev -w studio\"",
    "deploy": "docker compose -f docker-compose.release.yml up -d --build",
    "backup": "sh scripts/backup.sh",
    "restore": "sh scripts/restore.sh",
    "format": "prettier . --write"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "3.8.3"
  }
}
