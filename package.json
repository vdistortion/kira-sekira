{
  "name": "kira-sekira",
  "version": "3.0.0",
  "scripts": {
    "ng": "ng",
    "dev:up": "docker compose up -d",
    "dev:down": "docker compose down",
    "dev:clean": "docker compose down -v --rmi all",
    "dev:logs:db": "docker compose logs -f db",
    "dev:logs:studio": "docker compose logs -f studio",
    "start": "concurrently \"npm run start:main\" \"npm run start:models\"",
    "start:main": "ng serve main",
    "start:models": "ng serve models --port 4201",
    "build": "npm run build:shared && npm run build:main && npm run build:models",
    "build:main": "ng build main",
    "build:models": "ng build models",
    "build:shared": "ng build shared",
    "format": "prettier . --write"
  },
  "private": true,
  "packageManager": "npm@10.9.8",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.1",
    "@directus/sdk": "^22.0.0",
    "@tsparticles/angular": "^4.1.3",
    "@tsparticles/slim": "^4.1.3",
    "@twogate/ngx-photo-gallery": "^1.8.1",
    "express": "^5.1.0",
    "iconify-icon": "^3.0.2",
    "rxjs": "~7.8.0",
    "smooth-scroll": "^16.1.3",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@types/smooth-scroll": "^16.1.4",
    "concurrently": "^10.0.3",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2"
  }
}
