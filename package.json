{
  "name": "kira-sekira",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:clean": "docker compose down -v --rmi all",
    "db:logs": "docker compose logs -f db",
    "start:all": "concurrently \"npm run start -w @kira-sekira/site\" \"npm run start -w @kira-sekira/models\"",
    "format": "prettier . --write"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "3.8.3"
  }
}
